# Metis Viewer Pane — environment variables
#
# Spec: canonical-values.md §7 ports + env var fallbacks.
# Copy to .env.local for `next dev`; never commit .env files.

# Port Nexus runs on — used for the live /health probe in the status strip.
NEXT_PUBLIC_BACKEND_PORT=8000

# Polling interval (ms) for the /api/workspace/state filesystem watcher.
# Spec: viewer-pane.md §2 — default 1000ms, ≤1s latency target.
NEXT_PUBLIC_POLL_MS=1000

# Workspace root the chokidar watcher binds to. If unset the watcher
# resolves path.resolve(process.cwd(), '../../') from apps/web/.
# Override when running `next dev` from a non-canonical cwd.
# METIS_WORKSPACE_ROOT=/Users/you/repos/training/metis/workspaces/metis/week-04-supply-chain
