# Week 4 Supply Chain — environment template.
# Copy to `.env`; `scripts/run_backend.sh` sources it.
# Sole writer: shard 09 (workspaces/metis/week-04-supply-chain/todos/active/09-scaffold-support.md).
# Other shards READ from this file; they MUST NOT rewrite it.

# --- Backend ---------------------------------------------------------------
KAILASH_NEXUS_PORT=8000
KAILASH_ML_AUTOML_QUICK=1
DATABASE_URL_EXPERIMENTS=sqlite:///data/.experiments.db
DATABASE_URL_REGISTRY=sqlite:///data/.registry.db
DATABASE_URL_FEATURES=sqlite:///data/.features.db
ARTIFACT_DIR=data/

# --- Seeds (determinism) ---------------------------------------------------
# RANDOM_SEED pins AutoML's base RNG; AUTOML_SEED pins candidate sampling;
# DRIFT_SEED pins the post-drift window permutation. All three must be set
# for reproducibility across machines.
RANDOM_SEED=42
AUTOML_SEED=2026
DRIFT_SEED=78

# --- Viewer ----------------------------------------------------------------
NEXT_PUBLIC_POLL_MS=1000
NEXT_PUBLIC_BACKEND_PORT=8000
# METIS_WORKSPACE_ROOT — leave unset to auto-detect from src/backend/config.py.
# Only set this if running the backend from a non-standard working directory.
# METIS_WORKSPACE_ROOT=.

# --- LLM (only when kailash-ml[agents] is active — Week 4 does NOT exercise agents) ---
# optional: uncomment and populate if running agent-augmented prompts outside Week 4.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
